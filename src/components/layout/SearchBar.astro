<div class="site-search" data-site-search>
    <label class="sr-only" for="site-search-input">Search articles</label>
    <svg class="site-search-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.5-3.5"></path>
    </svg>
    <input
        id="site-search-input"
        class="site-search-input"
        type="search"
        placeholder="Search articles…"
        autocomplete="off"
        enterkeyhint="search"
        data-search-input
    />
    <div class="site-search-results" data-search-results hidden aria-live="polite"></div>
</div>

<script>
    type SearchItem = {
        title: string;
        description: string;
        content: string;
        tags: string[];
        href: string;
        type: string;
    };

    let searchIndex: SearchItem[] | undefined;
    let searchIndexRequest: Promise<SearchItem[]> | undefined;

    const getSearchIndex = () => {
        if (searchIndex) return Promise.resolve(searchIndex);
        if (!searchIndexRequest) {
            searchIndexRequest = fetch("/search.json")
                .then((response) => {
                    if (!response.ok) throw new Error("Unable to load search index");
                    return response.json();
                })
                .then((items: SearchItem[]) => {
                    searchIndex = items;
                    return items;
                });
        }
        return searchIndexRequest;
    };

    const makeResult = (item: SearchItem, query: string) => {
        const link = document.createElement("a");
        link.className = "site-search-result";
        link.href = item.href;

        const title = document.createElement("span");
        title.className = "site-search-result-title";
        title.textContent = item.title;

        const type = document.createElement("span");
        type.className = "site-search-result-type";
        type.textContent = item.type;

        const meta = document.createElement("span");
        meta.className = "site-search-result-meta";
        meta.append(title, type);
        link.append(meta);

        const source = `${item.description} ${item.content}`.replace(/\s+/g, " ").trim();
        const matchIndex = source.toLocaleLowerCase().indexOf(query);
        const start = Math.max(0, matchIndex - 56);
        const excerpt = source.slice(start, start + 160);

        if (excerpt) {
            const summary = document.createElement("span");
            summary.className = "site-search-result-summary";
            summary.textContent = `${start > 0 ? "…" : ""}${excerpt}${start + 160 < source.length ? "…" : ""}`;
            link.append(summary);
        }

        return link;
    };

    const initialiseSearch = () => {
        const search = document.querySelector<HTMLElement>("[data-site-search]");
        const input = search?.querySelector<HTMLInputElement>("[data-search-input]");
        const results = search?.querySelector<HTMLElement>("[data-search-results]");

        if (!search || !input || !results || search.dataset.initialised === "true") return;
        search.dataset.initialised = "true";

        let searchVersion = 0;

        const closeResults = () => {
            results.hidden = true;
            results.replaceChildren();
        };

        const renderMessage = (message: string) => {
            const element = document.createElement("p");
            element.className = "site-search-message";
            element.textContent = message;
            results.replaceChildren(element);
            results.hidden = false;
        };

        const searchContent = async () => {
            const query = input.value.trim().toLocaleLowerCase();
            const version = ++searchVersion;

            if (query.length < 2) {
                closeResults();
                return;
            }

            renderMessage("Searching…");

            try {
                const items = await getSearchIndex();
                if (version !== searchVersion) return;

                const matches = items
                    .map((item) => {
                        const title = item.title.toLocaleLowerCase();
                        const tags = item.tags.join(" ").toLocaleLowerCase();
                        const description = item.description.toLocaleLowerCase();
                        const content = item.content.toLocaleLowerCase();
                        const score =
                            (title.includes(query) ? 12 : 0) +
                            (tags.includes(query) ? 8 : 0) +
                            (description.includes(query) ? 4 : 0) +
                            (content.includes(query) ? 1 : 0);
                        return { item, score };
                    })
                    .filter(({ score }) => score > 0)
                    .sort((a, b) => b.score - a.score)
                    .slice(0, 6);

                if (matches.length === 0) {
                    renderMessage("No matching content found.");
                    return;
                }

                results.replaceChildren(...matches.map(({ item }) => makeResult(item, query)));
                results.hidden = false;
            } catch {
                renderMessage("Search is unavailable right now.");
            }
        };

        input.addEventListener("input", searchContent);
        input.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
                input.value = "";
                closeResults();
                input.blur();
            }
        });
        document.addEventListener("click", (event) => {
            if (!search.contains(event.target as Node)) closeResults();
        });
    };

    document.addEventListener("astro:page-load", initialiseSearch);
    initialiseSearch();
</script>
